[
    {  "_rem": "Extra 'virtual' Xcom datapoints"},

    {  "_rem": "These are not included in 'Studer Technical Specification - Xtender serial protocol appendix'"},
    {  "_rem": "But are defined by us based on other parameters exposed by the Xcom protocol"},

    {  "_rem": "Column descriptions:"},
    {  "_rem": "  fam  = Device Family"},
    {  "_rem": "  lvl  = User level required to access the param or info"},
    {  "_rem": "  pnr  = Parent number in menu structure"},
    {  "_rem": "  nr   = Number of the param or info"},
    {  "_rem": "  name = Friendly name of the param or info"},
    {  "_rem": "  urcc = Data unit of measurement as displayed on RCC"},
    {  "_rem": "  unit = Data unit of measurement"},
    {  "_rem": "  def  = Default value"},
    {  "_rem": "  min  = Minimum value"},
    {  "_rem": "  max  = Maximum value"},
    {  "_rem": "  fmt  = Data format"},
    {  "_rem": "  inc  = Increment step"},
    {  "_rem": "  opt  = Options for selection in Enums"},
    {  "_rem": "  rem  = Remarks"},
    

    {  "_rem": "###"},
    {  "_rem": "### Root Menu"},
